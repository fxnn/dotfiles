# 
# window appearance

#background = black -- not sure why I did this, but it doesn't work with light theme
background-opacity = 0.6
background-opacity-cells = true
background-blur = macos-glass-regular
# ugly and useless
macos-titlebar-proxy-icon = hidden
# tabs integrated to title bar, looks better and safes vertical space
macos-titlebar-style = tabs
# some padding to left+right looks better
window-padding-x = 5

macos-icon = holographic

font-size = 11
cursor-style = block

#theme = light:Modus Operandi,dark:
#theme = light:Primary,dark:
theme = light:Raycast Light,dark:Dracula
window-theme = system
